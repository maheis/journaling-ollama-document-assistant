[Unit]
Description=Ollama Document Assistant (dry-run scanner + review web)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/.local/share/ollama-document-assistant
ExecStart=%h/.local/share/ollama-document-assistant/.venv/bin/python %h/.local/share/ollama-document-assistant/doc_assistant_service.py --config-file %h/.local/share/ollama-document-assistant/assistant_config.json
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
